generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// ─── User ────────────────────────────────────────────────────────────
enum Role {
  ADMIN
  STUDENT
  TEACHER
}

model User {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  name         String
  email        String   @unique
  password     String
  role         Role     @default(STUDENT)
  avatar       String?
  isActive     Boolean  @default(true)
  isVerified   Boolean  @default(false)
  lastLogin    DateTime?
  refreshToken String?
  username     String?  @unique

  // Student profile fields
  firstName      String?
  lastName       String?
  dob            String?
  class          String?
  board          String?
  stream         String?
  school         String?
  city           String?
  target         String[]  // "Boards" | "NEET" | "JEE" | "Other"
  contactNumber  String?
  profilePicture String?
  address        String?
  isOnboarded    Boolean  @default(false)

  // Student gamification fields (persistent login streak & XP)
  streak         Int       @default(0)
  longestStreak  Int       @default(0)
  loginXp        Int       @default(0)
  lastActive     DateTime?
  bestRank       Int?

  // Security audit
  passwordChangedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  auditLogs     AuditLog[]
  uploadBatches UploadBatch[]
  sessions      Session[]
  otps          Otp[]
  quizAttempts  QuizAttempt[]     @relation("StudentAttempts")
  activities    StudentActivity[] @relation("StudentActivities")

  // Quiz Token System
  tokenWallet     QuizTokenWallet?
  transactions    TokenTransaction[]
  subscriptions   StudentSubscription[]
  payments        PaymentTransaction[]
  
  // Referral System
  referralCode    String?
  referredBy      String?   @db.ObjectId // User ID who referred this user
  referralsMade   Referral[] @relation("Referrer")
  referralRewards ReferralReward[]

  // Preferences
  preferences    UserPreference?

  // Activity & ranking (Phase 1: unified event feed + pluggable leaderboards)
  activityEvents ActivityEvent[]    @relation("UserActivityEvents")
  rankingScores  RankingScore[]
  rankSnapshots  RankingSnapshot[]
  badges         UserBadge[]
  periodStats    UserPeriodStats[]

  @@index([role])
  @@index([isVerified])
  @@index([class])
}

// ─── User Preference ────────────────────────────────────────────────
model UserPreference {
  id       String @id @default(auto()) @map("_id") @db.ObjectId
  userId   String @unique @db.ObjectId
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Appearance
  theme         String  @default("light") // "light" | "dark" | "auto"
  reduceMotion  Boolean @default(false)
  compactLayout Boolean @default(false)

  // Email Notifications (Coming Soon)
  emailWeeklyRank     Boolean @default(false)
  emailProductUpdates Boolean @default(false)

  // Push Notifications (In-app)
  pushStreakExpire    Boolean @default(true)
  pushRankMovement    Boolean @default(true)
  pushWeakTopics      Boolean @default(false)
  pushFriendJoins     Boolean @default(true)
  pushStreakReminder  Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Session ──────────────────────────────────────────────────────────
model Session {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  userId       String   @db.ObjectId
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshToken String   @unique
  userAgent    String?
  ipAddress    String?
  expiresAt    DateTime
  isRevoked    Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([expiresAt])
}

// ─── OTP ──────────────────────────────────────────────────────────────
enum OtpPurpose {
  EMAIL_VERIFICATION
  PASSWORD_RESET
  SENSITIVE_ACTION
}

model Otp {
  id        String     @id @default(auto()) @map("_id") @db.ObjectId
  userId    String     @db.ObjectId
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  code      String
  purpose   OtpPurpose
  expiresAt DateTime
  isUsed    Boolean    @default(false)
  attempts  Int        @default(0)

  createdAt DateTime @default(now())

  @@index([userId, purpose])
  @@index([expiresAt])
}

// ─── Question ────────────────────────────────────────────────────────
enum WorkflowStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED
  REJECTED
  PUBLISHED
}

enum QuestionType {
  MCQ
  MULTI_CORRECT
  ASSERTION_REASON
  CASE_BASED
  MATCH_THE_FOLLOWING
  TRUE_FALSE
  DIAGRAM_BASED
}

enum Difficulty {
  Easy
  Medium
  Hard
  Expert
}

type Option {
  id       String
  text     String
  imageUrl String?
}

type MatchPair {
  left  String
  right String
}

type SubQuestion {
  question      String
  options       Option[]
  correctAnswer String[]
}

type CaseStudy {
  passage         String?
  passageImageUrl String?
  subQuestions     SubQuestion[]
}

type AnswerExplanation {
  correctExplanation   String?
  incorrectExplanation Json?
}

type PreviousVersion {
  version      Int
  data         Json
  changedBy    String
  changedAt    DateTime
  changeReason String?
}

model Question {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  questionId String   @unique

  examType String[]
  class    String
  subject  String
  unit     String?
  chapter  String
  topic    String
  subTopic String?

  questionType QuestionType
  difficulty   Difficulty

  question         String
  questionImageUrl String?

  options    Option[]
  matchPairs MatchPair[]
  caseStudy  CaseStudy?

  assertionStatement String?
  reasonStatement    String?

  correctAnswer     String[]
  answerExplanation AnswerExplanation?

  PYQ_tags             String[]
  estimatedTimeSeconds Int     @default(60)
  marks                Float   @default(1)
  negativeMarks        Float   @default(0)

  isDiagramBased       Boolean  @default(false)
  isCaseBased          Boolean  @default(false)
  isNcertLineBased     Boolean  @default(false)
  commonMisconceptions String[]

  status           WorkflowStatus    @default(DRAFT)
  version          Int               @default(1)
  previousVersions PreviousVersion[]

  uploadedBy  String? @db.ObjectId
  reviewedBy  String? @db.ObjectId
  approvedBy  String? @db.ObjectId
  publishedBy String? @db.ObjectId

  reviewComment String?
  uploadBatchId String?
  contentHash   String?

  metadata Json?
  tags     String[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([subject])
  @@index([chapter])
  @@index([topic])
  @@index([questionType])
  @@index([difficulty])
  @@index([status])
  @@index([uploadedBy])
  @@index([contentHash])
  @@index([uploadBatchId])
  @@index([status, questionType])
  @@index([subject, chapter, topic])
}

// ─── Quiz ────────────────────────────────────────────────────────────
enum QuizStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

type QuizQuestion {
  questionId String
  order      Int
  marks      Float?
}

model Quiz {
  id       String @id @default(auto()) @map("_id") @db.ObjectId
  quizId   String @unique

  title       String
  description String?
  subject     String
  chapter     String?
  topic       String?
  className   String?
  examType    String[]

  questions QuizQuestion[]

  totalMarks     Float   @default(0)
  totalQuestions  Int     @default(0)
  timeLimitMins   Float   @default(60)
  negativeMarking Boolean @default(false)
  shuffleQuestions Boolean @default(false)

  difficulty String?
  tags       String[]

  paperType   String?    // null = regular quiz, "PRACTICE_PAPER" | "FULL_MOCK" | "PYQ"
  year        Int?       // For PYQ papers: 2024, 2023, etc.

  // Tokens deducted from the student's wallet on quiz start. Defaults to 1
  // so existing rows keep their current cost; admin editor can override per
  // quiz (e.g. higher cost for full mocks, free practice = 0).
  attemptCost Int      @default(1)

  // When true, attempts on this quiz contribute to global rank scoring AND
  // a per-quiz leaderboard scope is created on publish. False = practice-only.
  rankRewarding Boolean  @default(false)

  // Contest-style lifecycle for rank-rewarding quizzes:
  //   - quizStartsAt: leaderboard window opens (null = always open until close)
  //   - quizEndsAt:   leaderboard auto-closes when now > quizEndsAt (null = no auto-close)
  //   - isClosed/closedAt: set by the lifecycle cron (or admin override) once
  //     ranks are frozen. ONLY closed quizzes feed CLASS_GLOBAL scoring.
  quizStartsAt  DateTime?
  quizEndsAt    DateTime?
  isClosed      Boolean   @default(false)
  closedAt      DateTime?

  status    QuizStatus @default(DRAFT)
  createdBy String     @db.ObjectId

  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([subject])
  @@index([status])
  @@index([createdBy])
  @@index([createdAt])
  @@index([rankRewarding])
  @@index([rankRewarding, isClosed])
  @@index([rankRewarding, quizEndsAt])
}

// ─── Audit Log ───────────────────────────────────────────────────────
// ─── AI Generation ──────────────────────────────────────────────────
enum AiProvider {
  OPENAI
  GEMINI
  CLAUDE
}

enum AiJobStatus {
  PENDING
  PROCESSING
  COMPLETED
  PARTIAL
  FAILED
}

model AiGenerationJob {
  id        String      @id @default(auto()) @map("_id") @db.ObjectId
  jobId     String      @unique

  provider       AiProvider
  status         AiJobStatus  @default(PENDING)

  // Request config
  subject        String
  topic          String
  subTopic       String?
  questionTypes  Json         // [{ type: "MCQ", count: 5 }, ...]
  difficulty     Difficulty?
  className      String?
  examType       String[]
  additionalInstructions String?

  // Results
  totalRequested    Int        @default(0)
  totalGenerated    Int        @default(0)
  totalFailed       Int        @default(0)
  generatedQuestionIds String[]
  errors             Json?

  // Retry
  retryCount     Int        @default(0)
  maxRetries     Int        @default(3)
  parentJobId    String?

  requestedBy    String     @db.ObjectId
  completedAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  providerLogs AiProviderLog[]

  @@index([provider])
  @@index([status])
  @@index([requestedBy])
  @@index([createdAt])
}

model AiProviderLog {
  id       String @id @default(auto()) @map("_id") @db.ObjectId

  jobId    String @db.ObjectId
  job      AiGenerationJob @relation(fields: [jobId], references: [id])

  provider       AiProvider
  model          String
  promptTokens   Int        @default(0)
  completionTokens Int      @default(0)
  totalTokens    Int        @default(0)
  estimatedCost  Float      @default(0)
  latencyMs      Int        @default(0)

  requestPayload  Json?
  responsePayload Json?
  errorMessage    String?
  success         Boolean    @default(true)

  createdAt DateTime @default(now())

  @@index([jobId])
  @@index([provider])
  @@index([createdAt])
}

// ─── Audit Log ───────────────────────────────────────────────────────
enum AuditAction {
  CREATE
  UPDATE
  DELETE
  STATUS_CHANGE
  BULK_UPLOAD
  BULK_APPROVE
  BULK_REJECT
  AI_GENERATE
  LOGIN
  LOGOUT
  SIGNUP
  EMAIL_VERIFIED
  PASSWORD_RESET_REQUEST
  PASSWORD_RESET_COMPLETE
  OTP_SENT
  OTP_VERIFIED
  PROFILE_UPDATED
  SESSION_REVOKED
  TOKEN_REFRESHED
}

model AuditLog {
  id         String      @id @default(auto()) @map("_id") @db.ObjectId
  action     AuditAction
  entityType String
  entityId   String?

  performedBy     String @db.ObjectId
  performedByUser User   @relation(fields: [performedBy], references: [id])

  details       Json?
  previousState Json?
  newState      Json?
  ipAddress     String?
  userAgent     String?

  createdAt DateTime @default(now())

  @@index([action])
  @@index([performedBy])
  @@index([entityType, entityId])
  @@index([createdAt])
}

// ─── Upload Batch ────────────────────────────────────────────────────
enum BatchStatus {
  PROCESSING
  COMPLETED
  FAILED
  PARTIAL
}

type ValidationError {
  questionId String?
  index      Int
  errors     String[]
}

model UploadBatch {
  id       String @id @default(auto()) @map("_id") @db.ObjectId
  batchId  String @unique
  fileName String

  uploadedBy     String @db.ObjectId
  uploadedByUser User   @relation(fields: [uploadedBy], references: [id])

  totalQuestions     Int @default(0)
  validQuestions     Int @default(0)
  invalidQuestions   Int @default(0)
  duplicateQuestions Int @default(0)

  validationErrors ValidationError[]
  status           BatchStatus       @default(PROCESSING)
  questionIds      String[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([uploadedBy])
}

// ─── Quiz Attempt ────────────────────────────────────────────────────
enum AttemptStatus {
  IN_PROGRESS
  COMPLETED
  ABANDONED
  FAILED_PROCTORING
}

model QuizAttempt {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId

  studentId String   @db.ObjectId
  student   User     @relation("StudentAttempts", fields: [studentId], references: [id], onDelete: Cascade)

  quizId    String   @db.ObjectId

  // Snapshot of quiz metadata at attempt time
  quizTitle   String
  quizSubject String

  // Attempt details
  answers         Json?     // { questionId: selectedAnswer[] }
  score           Float     @default(0)
  totalMarks      Float     @default(0)
  percentage      Float     @default(0)
  correctCount    Int       @default(0)
  incorrectCount  Int       @default(0)
  unansweredCount Int       @default(0)
  timeTakenSecs   Int       @default(0)

  // State
  status    AttemptStatus  @default(IN_PROGRESS)
  proctoringViolations Json? // [{ type, timestamp, details }]

  // Once the student requests the correct answers, this flips true. We
  // then block any future retries of the same quiz so revealed answers
  // can't be exploited to game a higher score.
  answersRevealed   Boolean   @default(false)
  answersRevealedAt DateTime?

  // Per-question breakdown for topic analytics
  questionResults Json?   // [{ questionId, topic, subject, correct: bool, timeTakenSecs }]

  startedAt   DateTime  @default(now())
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([studentId])
  @@index([quizId])
  @@index([studentId, quizId])
  @@index([studentId, completedAt])
  @@index([status])
}

// ─── Proctoring evidence ─────────────────────────────────────────────
// Stores frames + audio clips captured during a proctored attempt.
// Hybrid capture strategy:
//   - HEARTBEAT: 1 frame every 30s while the attempt is active.
//   - BURST:     3 frames at 1s intervals, fired when a strike-severity
//                violation is reported. Linked back to the violation by
//                its (type, timestamp) so an auditor can pivot quickly.
//   - AUDIO:     ~10s rolling audio clip flushed at the same trigger as
//                BURST. Only shipped on demand — never streamed.
//   - EXIT:      single frame captured at submit time as the "exit photo".
// The actual blob lives in Cloudinary; this table is just the index that
// links a media asset to (attempt, violation).
model QuizAttemptEvidence {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId

  attemptId String   @db.ObjectId
  studentId String   @db.ObjectId

  kind      EvidenceKind
  // Where the frame came from. CAMERA = candidate's webcam, SCREEN =
  // their desktop / chosen display surface. Defaults to CAMERA so that
  // pre-existing rows (which all came from the webcam pipeline) continue
  // to render correctly without a backfill.
  source    EvidenceSource @default(CAMERA)
  mimeType  String
  url       String     // Cloudinary secure_url
  storageKey String    // Cloudinary public_id, for deletion + retention jobs

  // Optional link back to the violation that triggered the capture.
  // (HEARTBEAT and EXIT frames leave these null.)
  linkedViolationType      String?
  linkedViolationTimestamp DateTime?

  // Burst sequence index (1, 2, 3) for BURST kinds — lets the UI group
  // related frames into a single timeline marker.
  sequence  Int?

  capturedAt DateTime  @default(now())
  createdAt  DateTime  @default(now())

  @@index([attemptId])
  @@index([attemptId, kind])
  @@index([attemptId, source])
  @@index([studentId, capturedAt])
  // Supports the daily retention purge: "find rows where capturedAt <
  // threshold". Without this the cron does a full-collection scan,
  // which gets expensive once the table is in the hundreds of thousands.
  @@index([capturedAt])
}

enum EvidenceKind {
  HEARTBEAT
  BURST
  AUDIO    // legacy — no longer captured by client; kept so older rows still type-check
  EXIT
}

enum EvidenceSource {
  CAMERA
  SCREEN
}

// ─── Daily activity rollup ───────────────────────────────────────────
// One row per (user, UTC day). Aggregates login + quiz activity so we can
// render the streak garden (last 30–60 days) without scanning every event.
// Written by:
//   - auth flow (updateLoginStreak)        → loginCount++, loggedIn=true
//   - student quiz submit                  → quizzesCompleted++, questions, mins
// Rows are upserted on the fly; no nightly job needed.
model DailyActivity {
  id     String   @id @default(auto()) @map("_id") @db.ObjectId
  userId String   @db.ObjectId
  date   DateTime // UTC day-start (00:00:00.000Z)

  loggedIn          Boolean @default(false)
  loginCount        Int     @default(0)
  quizzesAttempted  Int     @default(0)   // includes IN_PROGRESS starts
  quizzesCompleted  Int     @default(0)
  questionsAnswered Int     @default(0)
  minutesActive     Int     @default(0)   // sum of quiz time-taken (mins)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, date])
}

// ─── Saved Quizzes (student bookmarks) ───────────────────────────────
model SavedQuiz {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  studentId String   @db.ObjectId
  quizId    String   @db.ObjectId
  savedAt   DateTime @default(now())

  @@unique([studentId, quizId])
  @@index([studentId, savedAt])
}

// ─── Student Activity ────────────────────────────────────────────────
model StudentActivity {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId

  studentId String   @db.ObjectId
  student   User     @relation("StudentActivities", fields: [studentId], references: [id], onDelete: Cascade)

  type      String   // quiz_completed | badge_unlocked | streak | profile_update | practice
  title     String
  meta      String?  // "92% · +280 XP"
  icon      String?  // "Trophy", "Flame", etc.
  tone      String?  // "emerald", "orange", etc.

  relatedId String?  // e.g. quizAttemptId or badgeId

  createdAt DateTime @default(now())

  @@index([studentId])
  @@index([studentId, createdAt])
}

// ─── Quiz Token System & Subscriptions ───────────────────────────────

enum SubscriptionStatus {
  ACTIVE
  PAUSED
  CANCELLED
  PAST_DUE
  EXPIRED
}

enum TokenTransactionType {
  PURCHASE
  QUIZ_CONSUMED
  REFERRAL_BONUS
  SUBSCRIPTION_REFRESH
  ADMIN_CREDIT
  REFUND
}

enum RefreshFrequency {
  MONTHLY
  QUARTERLY
  YEARLY
}

enum Cadence {
  MONTHLY
  ANNUAL
  ONE_TIME
}

enum FeatureValueType {
  CHECK
  CROSS
  TEXT
  NUMBER
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum PaymentMode {
  ONE_TIME
  SUBSCRIPTION
}

model QuizTokenWallet {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @unique @db.ObjectId
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  balance   Int      @default(0)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TokenTransaction {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  type      TokenTransactionType
  amount    Int      // positive for credit, negative for debit
  balanceAfter Int
  
  description String?
  referenceId String? // e.g. quizAttemptId, paymentId, referralId
  
  createdAt DateTime @default(now())
  
  @@index([userId])
  @@index([type])
  @@index([createdAt])
}

model SubscriptionPlan {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  description String?

  // Display-only metadata used by the public pricing page
  icon        String?      // lucide key: "leaf" | "rocket" | "crown" | ...
  badge       String?      // "Current" | "Most picked" | ...
  ctaLabel    String?      // override for the card CTA, e.g. "Go Pro"
  ctaVariant  String?      // "secondary" | "accent" | "lime"

  currency    String   @default("INR")

  isActive    Boolean  @default(true)
  isPopular   Boolean  @default(false)   // featured card
  isFree      Boolean  @default(false)   // free tier — usually has no pricing rows
  sortOrder   Int      @default(0)

  pricings      PlanPricing[]
  features      PlanFeature[]
  subscriptions StudentSubscription[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PlanPricing {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  planId      String   @db.ObjectId
  plan        SubscriptionPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  cadence     Cadence
  price       Float
  originalPrice Float?                 // for "save %" strike-through
  tokenCount  Int                      // tokens granted per refresh cycle
  tokenPeriodLabel String?             // "per month", "per year", "once"
  note        String?                  // "Renews monthly", "≈ ₹82.50 / month · 2 months free"
  isActive    Boolean  @default(true)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([planId, cadence])
  @@index([planId])
}

model PlanFeature {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  planId        String   @db.ObjectId
  plan          SubscriptionPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  sectionKey    String                  // "tokens-quizzes" | "insights" | "collaboration" | "support" | "card"
  sectionLabel  String                  // "Tokens & quizzes"

  label         String                  // "Monthly token allowance"
  valueType     FeatureValueType        // CHECK | CROSS | TEXT | NUMBER
  value         String?                 // null for CHECK/CROSS; otherwise the text/number value

  included      Boolean  @default(true) // false = strike/dimmed on card
  showOnCard    Boolean  @default(true)
  showInCompare Boolean  @default(true)
  isComingSoon  Boolean  @default(false) // renders a "Coming soon" chip next to the row

  // Stable key used by EntitlementsService to enforce access (e.g. MOCK_TESTS, PYQ_ACCESS).
  // null = display-only feature, no server-side gating.
  entitlementKey String?

  sortOrder     Int      @default(0)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([planId])
}

model StudentSubscription {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  planId    String   @db.ObjectId
  plan      SubscriptionPlan @relation(fields: [planId], references: [id])

  pricingId String?  @db.ObjectId   // the cadence variant the user subscribed to
  cadence   Cadence?                 // denormalised for fast queries

  status    SubscriptionStatus @default(ACTIVE)

  startDate DateTime @default(now())
  endDate   DateTime?
  nextRefreshDate DateTime?

  isAutoRenewEnabled Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
}

model PaymentTransaction {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  planId    String?  @db.ObjectId
  pricingId String?  @db.ObjectId   // which cadence variant was purchased
  cadence   Cadence?                 // denormalised for reporting

  amount    Float
  currency  String   @default("INR")
  status    PaymentStatus @default(PENDING)
  mode      PaymentMode

  gatewayPaymentId String?
  gatewayOrderId   String?
  gatewaySignature String?

  redeemCode       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
}

// ─── Redeem Codes ────────────────────────────────────────────────────

model RedeemCode {
  id                 String   @id @default(auto()) @map("_id") @db.ObjectId
  code               String   @unique
  discountPercentage Float
  maxUses            Int      @default(20)
  currentUses        Int      @default(0)
  isActive           Boolean  @default(true)
  expiresAt          DateTime?
  applicablePlanIds  String[] @db.ObjectId // If empty, code is valid for all plans
  
  usedBy             String[] @db.ObjectId // To track which users have used it
  
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

// ─── Referral System ──────────────────────────────────────────────────

model Referral {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  referrerId  String   @db.ObjectId
  referrer    User     @relation("Referrer", fields: [referrerId], references: [id], onDelete: Cascade)
  
  referredId  String   @unique @db.ObjectId // The user who signed up
  
  status      String   @default("PENDING") // PENDING, SUCCESS
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@index([referrerId])
}

model ReferralReward {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userId      String   @db.ObjectId // User receiving the reward
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  referralId  String   @db.ObjectId

  tokensAwarded Int    @default(2)

  createdAt DateTime @default(now())

  @@index([userId])
}

// ─── Activity Event Feed ─────────────────────────────────────────────
// Append-only ledger of every user-visible domain event. Replaces the
// freeform StudentActivity model long-term; both write in parallel during
// the cutover so the legacy /student/activity read path keeps working.

enum ActivityCategory {
  QUIZ
  RANK
  TOKEN
  BADGE
  STREAK
  PLAN
  SOCIAL
  SYSTEM
}

enum ActivityEventType {
  QUIZ_STARTED
  QUIZ_COMPLETED
  QUIZ_ABANDONED
  RANK_CHANGED
  TOKEN_CREDITED
  TOKEN_DEBITED
  TOKEN_PURCHASED
  BADGE_UNLOCKED
  STREAK_DAY
  STREAK_MILESTONE
  STREAK_BROKEN
  PLAN_PURCHASED
  PLAN_CANCELLED
  PLAN_REFRESHED
  REFERRAL_CONVERTED
  PROFILE_UPDATED
  ACCOUNT_CREATED
}

model ActivityEvent {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId

  userId    String   @db.ObjectId
  user      User     @relation("UserActivityEvents", fields: [userId], references: [id], onDelete: Cascade)

  type      ActivityEventType
  category  ActivityCategory

  // Pre-rendered, denormalized fields for the timeline (saves a join per row)
  title     String
  meta      String?
  icon      String?
  tone      String?

  // Structured payload — event-type-specific. Each producer has a typed payload
  // shape in events/event-payloads/*.ts.
  payload   Json?

  // Optional pointer back to the source entity that produced this event
  refType   String?         // "QuizAttempt" | "TokenTransaction" | "RankingSnapshot" | ...
  refId     String?         @db.ObjectId

  // Signed scalar for quick aggregation in stat-strip queries
  // (token delta, rank delta, score delta, etc.)
  amount    Float?

  occurredAt DateTime @default(now())
  createdAt  DateTime @default(now())

  @@index([userId, occurredAt(sort: Desc)])
  @@index([userId, category, occurredAt(sort: Desc)])
  @@index([userId, type, occurredAt(sort: Desc)])
}

// ─── Ranking Engine ──────────────────────────────────────────────────
// Pluggable leaderboard scopes. A "scope" defines who is being ranked
// (cohortFilter), how their score is computed (scorerKey), and how ties
// are broken (config). New leaderboards = new scope row, no schema change.

enum ScopeKind {
  CLASS_GLOBAL        // partitioned by User.class — the headline "global rank"
  TARGET_EXAM         // JEE / NEET / Boards
  SUBJECT             // Physics / Chemistry / Maths / Biology
  QUIZ                // per-quiz leaderboard, key = quizId
  COHORT              // school / friend group / teacher class (future)
  EVENT               // time-bounded challenges (future)
}

model RankingScope {
  id           String       @id @default(auto()) @map("_id") @db.ObjectId

  kind         ScopeKind
  key          String       // "Class 11" | "JEE" | "Physics" | "<quizId>" | "<cohortId>"
  displayName  String

  // Strategy keys are resolved at runtime to scorer implementations in
  // ranking/scorers/*. Swappable per scope without touching the engine.
  scorerKey    String       // "wrp" | "best-attempt" | "elo" | ...
  config       Json?        // strategy-specific: { halflifeDays, minAttempts, tieBreak, ... }

  // Membership predicate. The recompute job uses this to filter users.
  // Shape: { class?: string[], target?: string[], stream?: string[], cohortId?, quizId? }
  cohortFilter Json?

  isActive     Boolean      @default(true)
  lastComputedAt DateTime?

  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  scores       RankingScore[]
  snapshots    RankingSnapshot[]

  @@unique([kind, key])
  @@index([kind])
  @@index([isActive])
}

model RankingScore {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId

  scopeId    String   @db.ObjectId
  scope      RankingScope @relation(fields: [scopeId], references: [id], onDelete: Cascade)

  userId     String   @db.ObjectId
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  score      Float            // primary sort key — sorted DESC for rank
  tieBreaker Float?           // secondary sort (e.g. -timeTakenSecs for QUIZ scope)

  rank       Int?             // last computed rank; null until first snapshot
  prevRank   Int?             // rank before last recompute — drives RANK_CHANGED events

  // Snapshot of inputs that produced this score (for debugging + UI badges:
  // "ranked from 14 attempts · last 30 days")
  attempts   Int      @default(0)
  meta       Json?

  updatedAt  DateTime @updatedAt

  @@unique([scopeId, userId])
  @@index([scopeId, score(sort: Desc)])
  @@index([scopeId, rank])
  @@index([userId])
}

model RankingSnapshot {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId

  scopeId   String   @db.ObjectId
  scope     RankingScope @relation(fields: [scopeId], references: [id], onDelete: Cascade)

  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  rank      Int
  score     Float
  takenAt   DateTime         // truncated to UTC day-start

  createdAt DateTime @default(now())

  @@unique([scopeId, userId, takenAt])
  @@index([userId, scopeId, takenAt])
}

// ─── Badges ──────────────────────────────────────────────────────────
// Definitions + per-user unlock log. Rule evaluation happens in the
// BadgeProjector subscribing to relevant domain events.

model Badge {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  code        String   @unique          // "calc-slayer" | "streak-7" | "first-quiz"
  name        String
  description String
  icon        String
  tone        String                    // "violet" | "amber" | "emerald" | "cyan" | "lime" | "coral"

  // Free-form classification for the achievements shelf — currently
  // "milestone" | "volume" | "streak" | "accuracy" | "rank" | "social".
  category    String   @default("milestone")
  // Visual tier the UI maps to a ring + glow. Higher tiers render bigger.
  tier        String   @default("bronze") // "bronze" | "silver" | "gold" | "platinum"
  sortOrder   Int      @default(0)

  ruleType    String                    // "quiz-count" | "questions-answered" | "perfect-quiz" | "streak" | "accuracy-overall" | "subject-accuracy" | "rank-milestone" | "tokens-earned"
  ruleConfig  Json                      // strategy-specific predicate

  // Optional reward granted on unlock. Left as Json so admins can wire
  // tokens / XP / cosmetic perks without a schema change. Null/absent =
  // no reward (the current default — we want the achievement layer in
  // place before paying out anything).
  reward      Json?                     // e.g. { tokens: 5 } | { xp: 100 } | { cosmetic: 'crown-frame' }

  isActive    Boolean  @default(true)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  unlocks     UserBadge[]

  @@index([category, sortOrder])
  @@index([isActive])
}

model UserBadge {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId

  userId     String   @db.ObjectId
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  badgeId    String   @db.ObjectId
  badge      Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  unlockedAt DateTime @default(now())

  @@unique([userId, badgeId])
  @@index([userId, unlockedAt])
}

// ─── Period Stats Rollup ─────────────────────────────────────────────
// Daily-rolled-up per-user numbers powering the ActivityPage stat strip.
// One row per (user, periodEndDate, periodDays). Computed by a nightly job
// and on-demand on stat-strip read for "today" rows.

model UserPeriodStats {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId

  userId        String   @db.ObjectId
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  periodEndDate DateTime         // UTC day-start of the period's last day
  periodDays    Int              // 1 | 7 | 30 | 90

  // Stat-strip primitives
  quizzesTaken       Int      @default(0)
  avgAccuracy        Float    @default(0)
  rankStart          Int?
  rankEnd            Int?
  rankDelta          Int?              // signed (negative = climbed up)
  streakDaysInPeriod Int      @default(0)
  tokensEarned       Int      @default(0)
  tokensSpent        Int      @default(0)

  // Cached deltas vs the immediately-prior period of the same length
  prevQuizzesTaken   Int?
  prevAvgAccuracy    Float?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([userId, periodEndDate, periodDays])
  @@index([userId, periodEndDate])
}
