generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// ─── User ────────────────────────────────────────────────────────────
enum Role {
  ADMIN
  STUDENT
  TEACHER
}

model User {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  name         String
  email        String   @unique
  password     String
  role         Role     @default(STUDENT)
  avatar       String?
  isActive     Boolean  @default(true)
  isVerified   Boolean  @default(false)
  lastLogin    DateTime?
  refreshToken String?

  // Student profile fields
  firstName      String?
  lastName       String?
  class          String?
  school         String?
  target         String[]  // "Boards" | "NEET" | "JEE" | "Other"
  contactNumber  String?
  profilePicture String?
  address        String?
  isOnboarded    Boolean  @default(false)

  // Student gamification fields (persistent login streak & XP)
  streak         Int       @default(0)
  longestStreak  Int       @default(0)
  loginXp        Int       @default(0)
  lastActive     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  auditLogs     AuditLog[]
  uploadBatches UploadBatch[]
  sessions      Session[]
  otps          Otp[]
  quizAttempts  QuizAttempt[]     @relation("StudentAttempts")
  activities    StudentActivity[] @relation("StudentActivities")

  // Quiz Token System
  tokenWallet     QuizTokenWallet?
  transactions    TokenTransaction[]
  subscriptions   StudentSubscription[]
  payments        PaymentTransaction[]
  
  // Referral System
  referralCode    String?
  referredBy      String?   @db.ObjectId // User ID who referred this user
  referralsMade   Referral[] @relation("Referrer")
  referralRewards ReferralReward[]

  @@index([role])
  @@index([isVerified])
}

// ─── Session ──────────────────────────────────────────────────────────
model Session {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  userId       String   @db.ObjectId
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshToken String   @unique
  userAgent    String?
  ipAddress    String?
  expiresAt    DateTime
  isRevoked    Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([expiresAt])
}

// ─── OTP ──────────────────────────────────────────────────────────────
enum OtpPurpose {
  EMAIL_VERIFICATION
  PASSWORD_RESET
  SENSITIVE_ACTION
}

model Otp {
  id        String     @id @default(auto()) @map("_id") @db.ObjectId
  userId    String     @db.ObjectId
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  code      String
  purpose   OtpPurpose
  expiresAt DateTime
  isUsed    Boolean    @default(false)
  attempts  Int        @default(0)

  createdAt DateTime @default(now())

  @@index([userId, purpose])
  @@index([expiresAt])
}

// ─── Question ────────────────────────────────────────────────────────
enum WorkflowStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED
  REJECTED
  PUBLISHED
}

enum QuestionType {
  MCQ
  MULTI_CORRECT
  ASSERTION_REASON
  CASE_BASED
  MATCH_THE_FOLLOWING
  TRUE_FALSE
  DIAGRAM_BASED
}

enum Difficulty {
  Easy
  Medium
  Hard
  Expert
}

type Option {
  id       String
  text     String
  imageUrl String?
}

type MatchPair {
  left  String
  right String
}

type SubQuestion {
  question      String
  options       Option[]
  correctAnswer String[]
}

type CaseStudy {
  passage         String?
  passageImageUrl String?
  subQuestions     SubQuestion[]
}

type AnswerExplanation {
  correctExplanation   String?
  incorrectExplanation Json?
}

type PreviousVersion {
  version      Int
  data         Json
  changedBy    String
  changedAt    DateTime
  changeReason String?
}

model Question {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  questionId String   @unique

  examType String[]
  class    String
  subject  String
  unit     String?
  chapter  String
  topic    String
  subTopic String?

  questionType QuestionType
  difficulty   Difficulty

  question         String
  questionImageUrl String?

  options    Option[]
  matchPairs MatchPair[]
  caseStudy  CaseStudy?

  assertionStatement String?
  reasonStatement    String?

  correctAnswer     String[]
  answerExplanation AnswerExplanation?

  PYQ_tags             String[]
  estimatedTimeSeconds Int     @default(60)
  marks                Float   @default(1)
  negativeMarks        Float   @default(0)

  isDiagramBased       Boolean  @default(false)
  isCaseBased          Boolean  @default(false)
  isNcertLineBased     Boolean  @default(false)
  commonMisconceptions String[]

  status           WorkflowStatus    @default(DRAFT)
  version          Int               @default(1)
  previousVersions PreviousVersion[]

  uploadedBy  String? @db.ObjectId
  reviewedBy  String? @db.ObjectId
  approvedBy  String? @db.ObjectId
  publishedBy String? @db.ObjectId

  reviewComment String?
  uploadBatchId String?
  contentHash   String?

  metadata Json?
  tags     String[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([subject])
  @@index([chapter])
  @@index([topic])
  @@index([questionType])
  @@index([difficulty])
  @@index([status])
  @@index([uploadedBy])
  @@index([contentHash])
  @@index([uploadBatchId])
  @@index([status, questionType])
  @@index([subject, chapter, topic])
}

// ─── Quiz ────────────────────────────────────────────────────────────
enum QuizStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

type QuizQuestion {
  questionId String
  order      Int
  marks      Float?
}

model Quiz {
  id       String @id @default(auto()) @map("_id") @db.ObjectId
  quizId   String @unique

  title       String
  description String?
  subject     String
  chapter     String?
  topic       String?
  className   String?
  examType    String[]

  questions QuizQuestion[]

  totalMarks     Float   @default(0)
  totalQuestions  Int     @default(0)
  timeLimitMins   Float   @default(60)
  negativeMarking Boolean @default(false)
  shuffleQuestions Boolean @default(false)

  difficulty String?
  tags       String[]

  paperType   String?    // null = regular quiz, "PRACTICE_PAPER" | "FULL_MOCK" | "PYQ"
  year        Int?       // For PYQ papers: 2024, 2023, etc.

  status    QuizStatus @default(DRAFT)
  createdBy String     @db.ObjectId

  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([subject])
  @@index([status])
  @@index([createdBy])
  @@index([createdAt])
}

// ─── Audit Log ───────────────────────────────────────────────────────
// ─── AI Generation ──────────────────────────────────────────────────
enum AiProvider {
  OPENAI
  GEMINI
  CLAUDE
}

enum AiJobStatus {
  PENDING
  PROCESSING
  COMPLETED
  PARTIAL
  FAILED
}

model AiGenerationJob {
  id        String      @id @default(auto()) @map("_id") @db.ObjectId
  jobId     String      @unique

  provider       AiProvider
  status         AiJobStatus  @default(PENDING)

  // Request config
  subject        String
  topic          String
  subTopic       String?
  questionTypes  Json         // [{ type: "MCQ", count: 5 }, ...]
  difficulty     Difficulty?
  className      String?
  examType       String[]
  additionalInstructions String?

  // Results
  totalRequested    Int        @default(0)
  totalGenerated    Int        @default(0)
  totalFailed       Int        @default(0)
  generatedQuestionIds String[]
  errors             Json?

  // Retry
  retryCount     Int        @default(0)
  maxRetries     Int        @default(3)
  parentJobId    String?

  requestedBy    String     @db.ObjectId
  completedAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  providerLogs AiProviderLog[]

  @@index([provider])
  @@index([status])
  @@index([requestedBy])
  @@index([createdAt])
}

model AiProviderLog {
  id       String @id @default(auto()) @map("_id") @db.ObjectId

  jobId    String @db.ObjectId
  job      AiGenerationJob @relation(fields: [jobId], references: [id])

  provider       AiProvider
  model          String
  promptTokens   Int        @default(0)
  completionTokens Int      @default(0)
  totalTokens    Int        @default(0)
  estimatedCost  Float      @default(0)
  latencyMs      Int        @default(0)

  requestPayload  Json?
  responsePayload Json?
  errorMessage    String?
  success         Boolean    @default(true)

  createdAt DateTime @default(now())

  @@index([jobId])
  @@index([provider])
  @@index([createdAt])
}

// ─── Audit Log ───────────────────────────────────────────────────────
enum AuditAction {
  CREATE
  UPDATE
  DELETE
  STATUS_CHANGE
  BULK_UPLOAD
  BULK_APPROVE
  BULK_REJECT
  AI_GENERATE
  LOGIN
  LOGOUT
  SIGNUP
  EMAIL_VERIFIED
  PASSWORD_RESET_REQUEST
  PASSWORD_RESET_COMPLETE
  OTP_SENT
  OTP_VERIFIED
  PROFILE_UPDATED
  SESSION_REVOKED
  TOKEN_REFRESHED
}

model AuditLog {
  id         String      @id @default(auto()) @map("_id") @db.ObjectId
  action     AuditAction
  entityType String
  entityId   String?

  performedBy     String @db.ObjectId
  performedByUser User   @relation(fields: [performedBy], references: [id])

  details       Json?
  previousState Json?
  newState      Json?
  ipAddress     String?
  userAgent     String?

  createdAt DateTime @default(now())

  @@index([action])
  @@index([performedBy])
  @@index([entityType, entityId])
  @@index([createdAt])
}

// ─── Upload Batch ────────────────────────────────────────────────────
enum BatchStatus {
  PROCESSING
  COMPLETED
  FAILED
  PARTIAL
}

type ValidationError {
  questionId String?
  index      Int
  errors     String[]
}

model UploadBatch {
  id       String @id @default(auto()) @map("_id") @db.ObjectId
  batchId  String @unique
  fileName String

  uploadedBy     String @db.ObjectId
  uploadedByUser User   @relation(fields: [uploadedBy], references: [id])

  totalQuestions     Int @default(0)
  validQuestions     Int @default(0)
  invalidQuestions   Int @default(0)
  duplicateQuestions Int @default(0)

  validationErrors ValidationError[]
  status           BatchStatus       @default(PROCESSING)
  questionIds      String[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([uploadedBy])
}

// ─── Quiz Attempt ────────────────────────────────────────────────────
enum AttemptStatus {
  IN_PROGRESS
  COMPLETED
  ABANDONED
}

model QuizAttempt {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId

  studentId String   @db.ObjectId
  student   User     @relation("StudentAttempts", fields: [studentId], references: [id], onDelete: Cascade)

  quizId    String   @db.ObjectId

  // Snapshot of quiz metadata at attempt time
  quizTitle   String
  quizSubject String

  // Attempt details
  answers         Json?     // { questionId: selectedAnswer[] }
  score           Float     @default(0)
  totalMarks      Float     @default(0)
  percentage      Float     @default(0)
  correctCount    Int       @default(0)
  incorrectCount  Int       @default(0)
  unansweredCount Int       @default(0)
  timeTakenSecs   Int       @default(0)

  // State
  status    AttemptStatus  @default(IN_PROGRESS)

  // Per-question breakdown for topic analytics
  questionResults Json?   // [{ questionId, topic, subject, correct: bool }]

  startedAt   DateTime  @default(now())
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([studentId])
  @@index([quizId])
  @@index([studentId, quizId])
  @@index([studentId, completedAt])
  @@index([status])
}

// ─── Student Activity ────────────────────────────────────────────────
model StudentActivity {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId

  studentId String   @db.ObjectId
  student   User     @relation("StudentActivities", fields: [studentId], references: [id], onDelete: Cascade)

  type      String   // quiz_completed | badge_unlocked | streak | profile_update | practice
  title     String
  meta      String?  // "92% · +280 XP"
  icon      String?  // "Trophy", "Flame", etc.
  tone      String?  // "emerald", "orange", etc.

  relatedId String?  // e.g. quizAttemptId or badgeId

  createdAt DateTime @default(now())

  @@index([studentId])
  @@index([studentId, createdAt])
}

// ─── Quiz Token System & Subscriptions ───────────────────────────────

enum SubscriptionStatus {
  ACTIVE
  PAUSED
  CANCELLED
  PAST_DUE
  EXPIRED
}

enum TokenTransactionType {
  PURCHASE
  QUIZ_CONSUMED
  REFERRAL_BONUS
  SUBSCRIPTION_REFRESH
  ADMIN_CREDIT
  REFUND
}

enum RefreshFrequency {
  MONTHLY
  QUARTERLY
  YEARLY
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum PaymentMode {
  ONE_TIME
  SUBSCRIPTION
}

model QuizTokenWallet {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @unique @db.ObjectId
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  balance   Int      @default(0)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TokenTransaction {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  type      TokenTransactionType
  amount    Int      // positive for credit, negative for debit
  balanceAfter Int
  
  description String?
  referenceId String? // e.g. quizAttemptId, paymentId, referralId
  
  createdAt DateTime @default(now())
  
  @@index([userId])
  @@index([type])
  @@index([createdAt])
}

model SubscriptionPlan {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  description String?
  
  price       Float
  currency    String   @default("INR")
  
  tokenCount  Int      // e.g. 10, 25, 50
  
  isRecurring Boolean  @default(false)
  refreshFrequency RefreshFrequency?
  
  isActive    Boolean  @default(true)
  
  subscriptions StudentSubscription[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model StudentSubscription {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  planId    String   @db.ObjectId
  plan      SubscriptionPlan @relation(fields: [planId], references: [id])
  
  status    SubscriptionStatus @default(ACTIVE)
  
  startDate DateTime @default(now())
  endDate   DateTime?
  nextRefreshDate DateTime?
  
  isAutoRenewEnabled Boolean @default(true)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@index([userId])
  @@index([status])
}

model PaymentTransaction {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  planId    String?  @db.ObjectId // Optional, if linked to a plan
  
  amount    Float
  currency  String   @default("INR")
  status    PaymentStatus @default(PENDING)
  mode      PaymentMode
  
  gatewayPaymentId String?
  gatewayOrderId   String?
  gatewaySignature String?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@index([userId])
  @@index([status])
}

// ─── Referral System ──────────────────────────────────────────────────

model Referral {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  referrerId  String   @db.ObjectId
  referrer    User     @relation("Referrer", fields: [referrerId], references: [id], onDelete: Cascade)
  
  referredId  String   @unique @db.ObjectId // The user who signed up
  
  status      String   @default("PENDING") // PENDING, SUCCESS
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@index([referrerId])
}

model ReferralReward {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userId      String   @db.ObjectId // User receiving the reward
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  referralId  String   @db.ObjectId
  
  tokensAwarded Int    @default(2)
  
  createdAt DateTime @default(now())
  
  @@index([userId])
}
