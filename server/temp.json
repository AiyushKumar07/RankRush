            "subTopic": "Anaerobic Respiration",
            "questionType": "MULTI_CORRECT",
            "difficulty": "Hard",
            "question": "Which of the following are correct statements about anaerobic respiration?",
            "options": [
                {
                    "id": "A",
                    "text": "It takes place in the absence of oxygen"
                },
                {
                    "id": "B",
                    "text": "It produces a large amount of ATP compared to aerobic respiration"
                },
                {
                    "id": "C",
                    "text": "In yeast, it produces ethanol and carbon dioxide"
                },
                {
                    "id": "D",
                    "text": "In human muscles, it leads to the formation of lactic acid during vigorous exercise"
                }
            ],
            "correctAnswer": [
                "A",
                "C",
                "D"
            ],
            "marks": 2,
            "negativeMarks": 0.5,
            "answerExplanation": {
                "correctExplanation": "Anaerobic respiration occurs without oxygen. In yeast, it yields ethanol + CO2 (fermentation), and in human muscle cells under low oxygen (vigorous exercise), it produces lactic acid causing cramps. However, it produces only 2 ATP molecules — much LESS than aerobic respiration (which yields ~38 ATP), so option B is incorrect."
            },
            "status": "PUBLISHED"
