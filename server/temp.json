            "questionType": "ASSERTION_REASON",
            "difficulty": "Medium",
            "question": "Read the Assertion (A) and Reason (R) carefully and select the most appropriate option.",
            "assertionStatement": "Transpiration helps in the upward movement of water and minerals from roots to leaves in plants.",
            "reasonStatement": "Loss of water from the leaves creates a suction pull (transpiration pull) that draws water up through the xylem.",
            "options": [
                {
                    "id": "A",
                    "text": "Both A and R are true, and R is the correct explanation of A"
                },
                {
                    "id": "B",
                    "text": "Both A and R are true, but R is NOT the correct explanation of A"
                },
                {
                    "id": "C",
                    "text": "A is true but R is false"
                },
                {
                    "id": "D",
                    "text": "A is false but R is true"
                }
